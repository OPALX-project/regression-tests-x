/*
    Spin benchmark -- longitudinal B, transverse initial spin
    ----------------------------------------------------------

    Goal: validate the OPALX Thomas-BMT integrator against the exact
    analytic rotation in the simplest possible configuration.

    Setup:
      - Single mu-, no decay.
      - SOLENOID with uniform B = +1 T * z_hat over z in [0, 20] m.
      - DRIFT after the solenoid so the reference particle has a
        beamline to thread through.
      - Muon launched along +z_hat at gamma = 1.10. Because v is
        parallel to B the net Lorentz force is identically zero:
          gamma is rigorously constant
          the muon moves in a straight line in z
      - Initial spin in +x_hat (transverse to B).
        With v || B the BMT angular velocity collapses to
          Omega = -(q/m) * (1 + a) * B / gamma * z_hat
        which is constant. Spin rotates in the (x, y) plane at
          omega = (|q| B / m) * (1 + a) / gamma   ~  7.74e8 rad/s
        period T_s ~ 8.1 ns. The analytic solution is
          P(t) = ( cos(omega t), sin(omega t), 0 ).

    Concrete numerics (so the notebook can rebuild Omega):
      species mass    : m_mu        = 0.105658375500 GeV
      anomaly         : a_mu        = 1.16592061e-3
      reference gamma : gamma_0     = 1.10
      reference beta  : beta_0      = 0.4166
      reference bgz   : beta*gamma  = 0.4583
      B_z (design)    : 1.0 T  (KS = 1 with BF_Uniform_Large.T7)

    Run length & resolution:
      DT       = 1 ns    ->  omega * DT  ~ 0.77 rad/step;
                             the T-BMT pusher's sub-stepping path
                             (threshold 0.1 rad) is exercised here.
      MAXSTEPS = 100     ->  100 ns total  ~  12 spin periods.
      ZSTOP    = 50 m    ->  reference covers ~12.5 m in 100 ns;
                             MAXSTEPS triggers the stop, not ZSTOP.
      STATDUMPFREQ = 1   ->  per-step spin trace.
      PSDUMPFREQ   = 5   ->  ~20 h5 snapshots over the run.
      EBDUMP = TRUE      ->  per-particle Ex/Ey/Ez/Bx/By/Bz in h5,
                             so the notebook can rebuild Omega from
                             the field the simulation actually applied.
*/

OPTION, PSDUMPFREQ    = 5;
OPTION, STATDUMPFREQ  = 1;
OPTION, EBDUMP        = TRUE;
OPTION, BOUNDPDESTROY = 0;
OPTION, VERSION       = 10900;

Title, string="Spin benchmark: longitudinal B, transverse initial spin";

Value, {OPALVERSION};

// ----------------------------------------------------------------------------
// Parameters
// ----------------------------------------------------------------------------

REAL n_muons       = 1;
REAL bunch_charge  = 1.602176634e-19;
REAL gamma_initial = 1.10;

// ----------------------------------------------------------------------------
// Beamline: solenoid covering the full fieldmap z range, then a drift.
//
//   SOL z range: [0, 20] m  -- particle stays inside throughout the 100 ns
//                              run (it reaches z ~ 12.5 m at the end).
//   D1  z range: [20, 50] m -- gives the reference particle room.
//
// FMAPFN is relative to the test directory; the .local launcher cd's into it
// before invoking OPALX, so the fieldmap lives in ./fieldmaps/.
// ----------------------------------------------------------------------------

SOL: SOLENOID,
    L        = 20.0,
    ELEMEDGE = 0.0,
    KS       = 1.0,
    FMAPFN   = "fieldmaps/BF_Uniform_Large.T7";

D1: DRIFT,
    L        = 30.0,
    ELEMEDGE = 20.0;

myLine: Line = (SOL, D1);

// ----------------------------------------------------------------------------
// Distribution: exactly one particle. SIGMA* must be strictly nonzero --
// the Gaussian sampler scales its inverse-CDF bounds by sigma, and
// sigma = 0 makes those bounds collapse to [0, 0] and produces NaN
// position samples. 1e-15 is well below float precision in our units.
// ----------------------------------------------------------------------------

DistMuon: DISTRIBUTION, TYPE = GAUSS,
    SIGMAX    = 1e-15,
    SIGMAY    = 1e-15,
    SIGMAZ    = 1e-15,
    SIGMAPX   = 1e-15,
    SIGMAPY   = 1e-15,
    SIGMAPZ   = 1e-15,
    NPARTDIST = n_muons;

// ----------------------------------------------------------------------------
// Emission source: place the particle at z = 0 (entrance of the solenoid)
// with momentum along +z (the natural BEAM-GAMMA direction). No P0X/P0Y/P0Z
// overrides, no T0 deferral -- everything stays on the well-trodden path.
// ----------------------------------------------------------------------------

ES_Muon: EMISSIONSOURCE,
    DISTRIBUTION = DistMuon,
    R0X = 0.0,
    R0Y = 0.0,
    R0Z = 0.0,
    P0X = 0.0,
    P0Y = 0.0,
    P0Z = 0.0;

Sources_Muon: EMISSIONSOURCELIST = (ES_Muon);

// ----------------------------------------------------------------------------
// Muon BEAM: longitudinal launch via GAMMA in +z, transverse initial spin
// in +x. No GLOBALPROCESSES -> no decay.
// ----------------------------------------------------------------------------

MBEAM: BEAM,
    PARTICLE     = MUON,
    GAMMA        = gamma_initial,
    NALLOC       = n_muons,
    BCHARGE      = bunch_charge,
    SOURCES      = Sources_Muon,
    CHARGE       = -1,
    POLARIZATION = {1.0, 0.0, 0.0};                    // transverse to B

// ----------------------------------------------------------------------------
// No space charge.
// ----------------------------------------------------------------------------

FS1: Fieldsolver, TYPE = NONE,
    NX = 2, NY = 2, NZ = 2,
    PARFFTX = true,  PARFFTY = true,  PARFFTZ = false,
    BCFFTX  = OPEN,  BCFFTY  = OPEN,  BCFFTZ  = OPEN,
    BBOXINCR = 5,
    GREENSF  = STANDARD;

// ----------------------------------------------------------------------------
// Tracking
// ----------------------------------------------------------------------------

TRACK, LINE     = myLine,
       BEAMS    = {MBEAM},
       MAXSTEPS = 100,
       DT       = {1e-9},
       ZSTOP    = 50.0;

RUN, METHOD = "PARALLEL", FIELDSOLVER = FS1;
ENDTRACK;
QUIT;
