/*      swissfel-booster.in
        OPALX
        Partial SwissFEL Gun & Booster test, without Monitors, including SC
        This test covers:
            - Elements: RFCavity, TravelingWave, Solenoid 
            - Fieldmaps: Astra1DDynamic, Astra1DMagnetoStatic
			- Space charge OPEN solver with Dirichlet BCs
*/

OPTION, PSDUMPFREQ   = 1E9;  // Don't write H5
OPTION, STATDUMPFREQ = 10;
OPTION, AUTOPHASE    = 4;    // Always leave this on, unless doing a phase scan
OPTION, REPARTFREQ   = 5;
OPTION, STEPINFOFQ   = 100;	 // Print out every 100 turns

Title, string = "Swiss FEL Gun & Booster"; 

OPTION, VERSION      = 10900; 

Value, {OPALVERSION};

//------------------------------------------------------------------------ 
// Global Parameters 
//------------------------------------------------------------------------ 
REAL N                   = 8;        // FS grid size
REAL rf_freq             = 2997.912;  // RF frequency (MHz)
REAL n_particles         = 1024;       // Number of particles in simulation.
REAL beam_bunch_charge   = 200e-12;   // Charge of bunch (C)
REAL beam_current 		 = beam_bunch_charge * rf_freq * 1e6;  

//------------------------------------------------------------------------ 
// Initial Momentum Calculation  
//------------------------------------------------------------------------ 
REAL Edes 	 = 1.4e-9;                 // Initial Energy (GeV) (includes the effect of the first RF Cavity)
REAL gamma   = (Edes+EMASS)/EMASS;
REAL beta    = sqrt(1-(1/gamma^2));
REAL P0      = gamma*beta*EMASS;      // Initial Momentum (GeV/c)

// Printing initial energy parameters to terminal output.
Value, {Edes, gamma, beta, P0, P0 * 3e8};

//------------------------------------------------------------------------ 
// RF Gun
//------------------------------------------------------------------------ 
REAL gun_l   = 1.749820E-01;  // Gun length
REAL gun_f   = rf_freq;       // Gun frequency 

GUN: RFCavity, L = gun_l, VOLT = 100.0, ELEMEDGE = 0.0, TYPE = "STANDING",
     FMAPFN = "fieldmaps/SwissFEL_Feb2011.T7", FREQ = gun_f, LAG = (Pi)/180.0*(-2.3);

//------------------------------------------------------------------------ 
// Solenoids
//------------------------------------------------------------------------ 
REAL KBF = 0.2081;

REAL KS1TW1 = 0.023026;
REAL KS2TW1 = 0.023026;
REAL KS3TW1 = 0.094228;
REAL KS4TW1 = 0.094228;

BF: Solenoid, L = 0.3, ELEMEDGE=0.3, KS = KBF, 
	FMAPFN = "fieldmaps/NEW_SINGLE_SOL_NOFRINGE_ASTRA.T7";

S1TW1: Solenoid, L = 1.5, ELEMEDGE=3.3, KS = KS1TW1, 
	   FMAPFN = "fieldmaps/INSB_MSLAC_Bz_NOFRINGE_ASTRA.T7";
S2TW1: Solenoid, L = 1.5, ELEMEDGE=4.2, KS = KS2TW1, 
	   FMAPFN = "fieldmaps/INSB_MSLAC_Bz_NOFRINGE_ASTRA.T7";
S3TW1: Solenoid, L = 1.5, ELEMEDGE=5.05, KS = KS3TW1, 
	   FMAPFN = "fieldmaps/INSB_MSLAC_Bz_NOFRINGE_ASTRA.T7";
S4TW1: Solenoid, L = 1.5, ELEMEDGE=5.9, KS = KS4TW1, 
	   FMAPFN = "fieldmaps/INSB_MSLAC_Bz_NOFRINGE_ASTRA.T7";

//------------------------------------------------------------------------ 
// Linac 1 & 2 
//------------------------------------------------------------------------ 
REAL linac_f = rf_freq;

REAL TW1_phi = 0.0;
REAL TW1_volt = 19.0;

REAL dz = 0.05;    
TW1: TravelingWave, L = 2.80, VOLT = TW1_volt, FMAPFN = "fieldmaps/TWS_PSI_Sband_ASTRA.T7", 
	 ELEMEDGE = 3.3 + dz, NUMCELLS = 121, MODE = 1/3, FREQ = linac_f, LAG = TW1_phi;

//------------------------------------------------------------------------ 
// DEFINE BEAM LINE
//------------------------------------------------------------------------ 
SWISSFEL: Line = (GUN, BF, TW1, S1TW1, S2TW1, S3TW1, S4TW1);

//------------------------------------------------------------------------ 
// INITIAL DISTRIBUTION FROM FILE
//------------------------------------------------------------------------
Dist: 	DISTRIBUTION, TYPE = EMITTEDFROMFILE,
    	FNAME = "opal-flattop-1bin-astra.dat",
    	EMITTED = true,
        TRISE = 1.0745e-12,
        TFALL = 1.0745e-12,
        TPULSEFWHM = 4.0e-12,
        CUTOFFLONG = 4.0,
    	EMISSIONSTEPS = 100,
    	NPARTDIST = n_particles;

ES1: 	EMISSIONSOURCE, DISTRIBUTION = Dist,
    	ZEROFACE_MAXSTEPS = 5000,
    	EMISSIONMODEL = NONE, // ASTRA not allowed with EMITTEDFROMFILE
    	SHIFTED_GREENS_FUNCTION = true; 

mySources: EMISSIONSOURCELIST = (ES1);

//------------------------------------------------------------------------
// Define Field solvers 
//------------------------------------------------------------------------ 
BINS1: 	BINNING, 
	   	MAXBINS = 1,
	   	TABLEPRINTFREQ = 100,
	   	PARAMETER = GAMMAZ,
	   	ADAPTIVEBINNING = false;

FS_SC: 	Fieldsolver, TYPE = OPEN, BINS = BINS1,
		NX = N, 
		NY = N, 
		NZ = N, 
		PARFFTX = false, 
		PARFFTY = false,
       	PARFFTZ = true,
		BCFFTX = open, 
		BCFFTY = open, 
		BCFFTZ = open, 
		GREENSF = STANDARD, BBOXINCR=5;

//------------------------------------------------------------------------
// Electron Beam Definition
//------------------------------------------------------------------------
BEAM1:  BEAM, PARTICLE = ELECTRON, 
		NALLOC = n_particles,
		SOURCES = mySources, 
		BCHARGE = beam_bunch_charge,
		CHARGE = -1;

//------------------------------------------------------------------------
// Run Simulation
//------------------------------------------------------------------------
TRACK, LINE = SWISSFEL, BEAM = BEAM1, MAXSTEPS = 5000, 
			  DT = {4.0e-13, 16.0e-12}, ZSTOP={0.20, 8.0};

RUN, METHOD = "PARALLEL", FIELDSOLVER = FS_SC;

ENDTRACK;

STOP;